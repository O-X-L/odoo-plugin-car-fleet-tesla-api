<?xml version="1.0" ?>
<odoo>
    <record id="fleet_tesla_group_user" model="res.groups">
        <field name="name">Tesla Fleet Officer</field>
        <field name="category_id" ref="base.module_category_human_resources_fleet"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="fleet_tesla_group_manager" model="res.groups">
        <field name="name">Tesla Fleet Administrator</field>
        <field name="implied_ids" eval="[(4, ref('fleet_tesla_group_user'))]"/>
        <field name="category_id" ref="base.module_category_human_resources_fleet"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
    <data noupdate="1">
    </data>
</odoo>
